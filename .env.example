NODE_ENV=production
PORT=3000

# MongoDB — required (same cluster as preferences/utils is fine)
MONGO_URI=mongodb://127.0.0.1:27017
# MONGODB_URI=  # alias

# Cloudinary — required for uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Comma-separated browser origins (required when NODE_ENV=production)
# CORS_ORIGINS=http://localhost:3000,https://servease-innovation.netlify.app
CORS_ORIGINS=
